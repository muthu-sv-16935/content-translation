{
  "name": "webpage-translator",
  "private": true,
  "version": "1.0.0",
  "description": "Translate webpages via LibreTranslate",
  "type": "module",
  "scripts": {
    "start": "npm run build && cd server && node server.js",
    "server": "cd server && node server.js",
    "client": "vite",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.0.0",
    "prettier": "^3.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^5.0.8"
  }
}