PORT=3002

# Translation uses MyMemory by default (no setup, no connection to port 8000).
# Only set USE_PYTHON_SERVICE=true if you run the Python NLLB server on port 8000.
# USE_PYTHON_SERVICE=true
# PYTHON_SERVICE_URL=http://127.0.0.1:8000

# LibreTranslate (free, open-source). Default: https://libretranslate.com
# Get a free API key at https://portal.libretranslate.com (required for libretranslate.com)
# Or use a self-hosted instance (no key needed).
# LIBRETRANSLATE_API_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=your_api_key

# Short-text enhancement: log raw, context-injected, and selected translation for short inputs.
# SHORT_TEXT_DEBUG=true
